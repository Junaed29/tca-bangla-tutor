---
import { SITE } from '../consts';
---
<header data-site-header class="site-header border-b border-[rgb(var(--border))] bg-[rgb(var(--surface))]/85 backdrop-blur sticky top-0 z-30 transition-transform duration-300 will-change-transform">
  <div class="max-w-6xl mx-auto px-4 py-3 flex items-center gap-4">
    <a href="/" class="flex items-center gap-2 no-underline" aria-label="হোম">
      <span aria-hidden="true" class="inline-flex w-9 h-9 items-center justify-center rounded-full bg-[rgb(var(--code-bg))] border border-[rgb(var(--border))] text-lg">🍵</span>
      <span class="font-bold text-[rgb(var(--text))] text-lg leading-none whitespace-nowrap">{SITE.title}</span>
    </a>

    <nav class="hidden md:flex items-center gap-4 ml-4 text-sm">
      <a href="/" class="text-[rgb(var(--text-muted))] hover:text-[rgb(var(--primary))] no-underline">হোম</a>
      <a href="/chapters/00-shuru-korar-age" class="text-[rgb(var(--text-muted))] hover:text-[rgb(var(--primary))] no-underline">অধ্যায়</a>
      <a href="/glossary" class="text-[rgb(var(--text-muted))] hover:text-[rgb(var(--primary))] no-underline">শব্দার্থ</a>
      <a href="/about" class="text-[rgb(var(--text-muted))] hover:text-[rgb(var(--primary))] no-underline">কেন এই সাইট</a>
    </nav>

    <div class="ml-auto flex items-center gap-2">
      <button
        type="button"
        data-search-open
        aria-label="খুঁজে দেখো"
        class="inline-flex items-center gap-1.5 px-2.5 py-1.5 rounded-md border border-[rgb(var(--border))] bg-[rgb(var(--bg))] text-[rgb(var(--text-muted))] hover:text-[rgb(var(--primary))] text-sm">
        <svg aria-hidden="true" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="7"/><path d="m20 20-3.5-3.5"/></svg>
        <span class="hidden sm:inline">খুঁজে দেখো…</span>
      </button>

      <button
        type="button"
        data-theme-toggle
        aria-label="থিম পরিবর্তন"
        title="থিম পরিবর্তন"
        class="inline-flex items-center justify-center w-9 h-9 rounded-md border border-[rgb(var(--border))] bg-[rgb(var(--bg))] text-[rgb(var(--text-muted))] hover:text-[rgb(var(--primary))]">
        <svg aria-hidden="true" class="block dark:hidden" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="4"/><path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M4.93 19.07l1.41-1.41M17.66 6.34l1.41-1.41"/></svg>
        <svg aria-hidden="true" class="hidden dark:block" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/></svg>
      </button>
    </div>
  </div>

  <!-- Search modal -->
  <dialog id="search-dialog" class="backdrop:bg-black/40 rounded-xl border border-[rgb(var(--border))] bg-[rgb(var(--surface))] text-[rgb(var(--text))] w-[min(640px,95vw)] p-0 mx-auto mt-[10vh]">
    <div class="p-4">
      <div class="flex items-center justify-between mb-3">
        <h2 class="text-lg font-bold m-0">খুঁজে দেখো</h2>
        <button type="button" data-search-close aria-label="বন্ধ" class="text-[rgb(var(--text-muted))] hover:text-[rgb(var(--primary))]">✕</button>
      </div>
      <div id="search"></div>
    </div>
  </dialog>

  <script>
    import '@pagefind/default-ui/css/ui.css';

    let pagefindUI: any = null;

    function setupSearch() {
      const dialog = document.getElementById('search-dialog') as HTMLDialogElement | null;
      const openBtn = document.querySelector('[data-search-open]') as HTMLButtonElement | null;
      const closeBtn = document.querySelector('[data-search-close]') as HTMLButtonElement | null;
      if (!dialog || !openBtn || !closeBtn) return;

      const ensureUI = async () => {
        if (pagefindUI) return;
        try {
          // @ts-expect-error - bundled at build time by Pagefind
          const mod = await import('@pagefind/default-ui');
          const PagefindUI = mod.PagefindUI;
          pagefindUI = new PagefindUI({
            element: '#search',
            showSubResults: true,
            showImages: false,
            translations: {
              placeholder: 'খুঁজে দেখো…',
              clear_search: 'মুছে দাও',
              load_more: 'আরও দেখো',
              search_label: 'খোঁজো',
              filters_label: 'ফিল্টার',
              zero_results: 'কিছু পাইনি — অন্য শব্দ try করে দেখো',
              many_results: '[COUNT] টা ফলাফল [SEARCH_TERM] -এর জন্য',
              one_result: '১ টা ফলাফল [SEARCH_TERM] -এর জন্য',
              alt_search: 'কোনো ফলাফল নেই [SEARCH_TERM]-এ, [DIFFERENT_TERM] দেখাচ্ছি',
              search_suggestion: 'কিছু পাইনি [SEARCH_TERM]-এ। try করো:',
              searching: 'খুঁজছি…',
            },
          });
        } catch (e) {
          const el = document.getElementById('search');
          if (el) el.innerHTML = '<p style="color:rgb(var(--text-muted))">Search index এখনো build হয়নি — production build-এ কাজ করবে।</p>';
        }
      };

      openBtn.addEventListener('click', async () => {
        await ensureUI();
        dialog.showModal();
        setTimeout(() => {
          const input = dialog.querySelector<HTMLInputElement>('input[type="text"]');
          input?.focus();
        }, 50);
      });
      closeBtn.addEventListener('click', () => dialog.close());
      dialog.addEventListener('click', (e) => {
        if (e.target === dialog) dialog.close();
      });
    }

    document.addEventListener('astro:page-load', setupSearch);

    // Auto-hide on scroll-down, reveal on scroll-up.
    let lastY = window.scrollY;
    let ticking = false;
    const SHOW_THRESHOLD = 6;   // px — ignore tiny jitter
    const PINNED_UNTIL  = 80;   // px — always show near top

    function onScroll() {
      if (ticking) return;
      ticking = true;
      requestAnimationFrame(() => {
        const header = document.querySelector('[data-site-header]') as HTMLElement | null;
        if (!header) { ticking = false; return; }

        const y = window.scrollY;
        const dy = y - lastY;
        const dialog = document.getElementById('search-dialog') as HTMLDialogElement | null;
        const searchOpen = dialog?.open === true;

        if (y < PINNED_UNTIL || searchOpen) {
          header.classList.remove('header-hidden');
        } else if (dy > SHOW_THRESHOLD) {
          header.classList.add('header-hidden');     // scrolling down → hide
        } else if (dy < -SHOW_THRESHOLD) {
          header.classList.remove('header-hidden');  // scrolling up → show
        }

        lastY = y;
        ticking = false;
      });
    }

    function setupAutoHide() {
      lastY = window.scrollY;
      // Make sure header is visible on every navigation.
      document.querySelector('[data-site-header]')?.classList.remove('header-hidden');
    }

    window.addEventListener('scroll', onScroll, { passive: true });
    document.addEventListener('astro:page-load', setupAutoHide);
  </script>

  <style>
    .site-header.header-hidden {
      transform: translateY(-100%);
    }
    @media (prefers-reduced-motion: reduce) {
      .site-header { transition: none; }
    }
  </style>
</header>
