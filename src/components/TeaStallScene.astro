---
interface Props {
  caption?: string;
  highlight?: 'board' | 'mama' | 'customer' | 'boy' | null;
}
const { caption, highlight = null } = Astro.props;

const dim = (id: string) => (highlight && highlight !== id) ? 'opacity: 0.45;' : '';
---
<figure class="not-prose my-8 mx-auto max-w-3xl">
  <svg
    role="img"
    aria-labelledby="tea-stall-title tea-stall-desc"
    viewBox="0 0 800 460"
    xmlns="http://www.w3.org/2000/svg"
    class="w-full h-auto rounded-xl border border-[rgb(var(--border))] bg-[rgb(var(--callout-tea))]"
  >
    <title id="tea-stall-title">চা স্টলের দৃশ্য</title>
    <desc id="tea-stall-desc">
      একটা চা স্টল, মামা মাঝখানে, পেছনে সাদা বোর্ডে অর্ডারের লিস্ট,
      বাঁ পাশে কাস্টমার অর্ডার দিচ্ছে, ডান পাশে ছোট ভাই দুধ আনতে দৌড়াচ্ছে।
    </desc>

    <!-- Sky / background gradient -->
    <defs>
      <linearGradient id="sky" x1="0" x2="0" y1="0" y2="1">
        <stop offset="0%" stop-color="#FFE9C7" />
        <stop offset="100%" stop-color="#FFF8EE" />
      </linearGradient>
      <linearGradient id="wood" x1="0" x2="0" y1="0" y2="1">
        <stop offset="0%" stop-color="#A06535" />
        <stop offset="100%" stop-color="#7A4824" />
      </linearGradient>
      <linearGradient id="roof" x1="0" x2="0" y1="0" y2="1">
        <stop offset="0%" stop-color="#8B5A2B" />
        <stop offset="100%" stop-color="#6B4220" />
      </linearGradient>
    </defs>

    <rect x="0" y="0" width="800" height="380" fill="url(#sky)" />
    <rect x="0" y="380" width="800" height="80" fill="#D8C7A0" />

    <!-- Roof -->
    <polygon points="120,140 580,140 620,180 80,180" fill="url(#roof)" />
    <rect x="80" y="178" width="540" height="6" fill="#5C3818" />

    <!-- Back wall (where the board hangs) -->
    <rect x="140" y="180" width="460" height="220" fill="#F1E2BB" />

    <!-- BOARD (State) -->
    <g style={dim('board')}>
      <rect x="200" y="200" width="280" height="160" rx="6" fill="#FFFFFF" stroke="#2D2A26" stroke-width="3" />
      <rect x="200" y="200" width="280" height="22" fill="#2D2A26" />
      <text x="340" y="216" text-anchor="middle" fill="#FFF8EE" font-family="'Noto Sans Bengali', sans-serif" font-size="13" font-weight="700">State (বোর্ড)</text>

      <!-- Order lines -->
      <text x="216" y="248" font-family="'Noto Sans Bengali', sans-serif" font-size="13" fill="#2D2A26">১। ১ কাপ চা, টেবিল ২</text>
      <text x="216" y="270" font-family="'Noto Sans Bengali', sans-serif" font-size="13" fill="#2D2A26">২। ২ কাপ চা, টেবিল ৫</text>
      <text x="216" y="292" font-family="'Noto Sans Bengali', sans-serif" font-size="13" fill="#2D2A26">৩। সিঙ্গাড়া ৪টা</text>
      <line x1="216" y1="312" x2="464" y2="312" stroke="#E8DDC9" stroke-width="1" />
      <text x="216" y="332" font-family="'Noto Sans Bengali', sans-serif" font-size="12" fill="#6B6259">দুধ: ১/২ লিটার</text>
      <text x="216" y="350" font-family="'Noto Sans Bengali', sans-serif" font-size="12" fill="#6B6259">কেটলি: গরম</text>

      <!-- Label arrow -->
      <text x="498" y="270" font-family="'Noto Sans Bengali', sans-serif" font-size="13" font-weight="700" fill="#8B5A2B">= State</text>
      <path d="M 482 264 L 496 264" stroke="#8B5A2B" stroke-width="2" marker-end="url(#arrow)" fill="none" />
    </g>

    <!-- Counter -->
    <rect x="160" y="395" width="480" height="40" fill="url(#wood)" />
    <rect x="160" y="392" width="480" height="6" fill="#5C3818" />

    <!-- Glass display (View) -->
    <rect x="180" y="370" width="160" height="25" fill="#FFFFFF" fill-opacity="0.6" stroke="#8B5A2B" stroke-width="1.5" rx="3" />
    <text x="260" y="388" text-anchor="middle" font-family="'Noto Sans Bengali', sans-serif" font-size="11" fill="#6B6259">কাচের কাউন্টার = View</text>

    <!-- MAMA (Reducer) -->
    <g style={dim('mama')} transform="translate(540, 250)">
      <!-- body -->
      <ellipse cx="0" cy="80" rx="38" ry="50" fill="#5C8A4E" />
      <!-- head -->
      <circle cx="0" cy="20" r="26" fill="#E8B07A" />
      <!-- moustache -->
      <ellipse cx="0" cy="28" rx="12" ry="3" fill="#2D2A26" />
      <!-- eyes -->
      <circle cx="-8" cy="18" r="2" fill="#2D2A26" />
      <circle cx="8" cy="18" r="2" fill="#2D2A26" />
      <!-- topi -->
      <rect x="-22" y="-2" width="44" height="6" fill="#FFFFFF" />
      <path d="M -22 -2 Q 0 -22 22 -2" fill="#FFFFFF" />
      <!-- arm pointing at board -->
      <line x1="-30" y1="60" x2="-78" y2="20" stroke="#E8B07A" stroke-width="10" stroke-linecap="round" />
      <!-- label -->
      <text x="0" y="150" text-anchor="middle" font-family="'Noto Sans Bengali', sans-serif" font-size="13" font-weight="700" fill="#2D2A26">মামা</text>
      <text x="0" y="166" text-anchor="middle" font-family="'Noto Sans Bengali', sans-serif" font-size="11" fill="#8B5A2B">= Reducer</text>
    </g>

    <!-- CUSTOMER (left) -->
    <g style={dim('customer')} transform="translate(95, 290)">
      <!-- body -->
      <ellipse cx="0" cy="60" rx="28" ry="42" fill="#C97A5C" />
      <!-- head -->
      <circle cx="0" cy="10" r="22" fill="#E8B07A" />
      <!-- hair -->
      <path d="M -20 4 Q 0 -16 20 4 L 20 -2 Q 0 -22 -20 -2 Z" fill="#2D2A26" />
      <!-- eyes -->
      <circle cx="-7" cy="10" r="2" fill="#2D2A26" />
      <circle cx="7" cy="10" r="2" fill="#2D2A26" />
      <!-- speech bubble -->
      <g transform="translate(20, -30)">
        <rect x="0" y="0" width="130" height="42" rx="10" fill="#FFFFFF" stroke="#8B5A2B" stroke-width="1.5" />
        <polygon points="10,42 18,52 26,42" fill="#FFFFFF" stroke="#8B5A2B" stroke-width="1.5" />
        <polygon points="11,42 18,51 25,42" fill="#FFFFFF" />
        <text x="65" y="20" text-anchor="middle" font-family="'Noto Sans Bengali', sans-serif" font-size="13" font-weight="700" fill="#2D2A26">মামা, এক কাপ চা!</text>
        <text x="65" y="35" text-anchor="middle" font-family="'Noto Sans Bengali', sans-serif" font-size="10" fill="#8B5A2B">= Action</text>
      </g>
      <!-- label -->
      <text x="0" y="130" text-anchor="middle" font-family="'Noto Sans Bengali', sans-serif" font-size="13" font-weight="700" fill="#2D2A26">কাস্টমার</text>
      <text x="0" y="146" text-anchor="middle" font-family="'Noto Sans Bengali', sans-serif" font-size="11" fill="#8B5A2B">= View</text>
    </g>

    <!-- BOY running with milk (Effect) -->
    <g style={dim('boy')} transform="translate(700, 300)">
      <!-- body -->
      <ellipse cx="0" cy="50" rx="20" ry="32" fill="#4A6FB0" />
      <!-- head -->
      <circle cx="0" cy="10" r="16" fill="#E8B07A" />
      <circle cx="-4" cy="10" r="1.5" fill="#2D2A26" />
      <circle cx="4" cy="10" r="1.5" fill="#2D2A26" />
      <path d="M -3 16 Q 0 19 3 16" stroke="#2D2A26" stroke-width="1.5" fill="none" />
      <!-- milk can in hand -->
      <rect x="-30" y="35" width="14" height="20" fill="#C0C0C0" stroke="#2D2A26" stroke-width="1" />
      <rect x="-30" y="33" width="14" height="4" fill="#888" />
      <!-- running legs -->
      <line x1="-5" y1="78" x2="-12" y2="98" stroke="#2D2A26" stroke-width="6" stroke-linecap="round" />
      <line x1="5" y1="78" x2="14" y2="92" stroke="#2D2A26" stroke-width="6" stroke-linecap="round" />
      <!-- motion lines -->
      <line x1="22" y1="40" x2="34" y2="42" stroke="#6B6259" stroke-width="2" stroke-linecap="round" />
      <line x1="22" y1="55" x2="36" y2="58" stroke="#6B6259" stroke-width="2" stroke-linecap="round" />
      <line x1="22" y1="70" x2="32" y2="74" stroke="#6B6259" stroke-width="2" stroke-linecap="round" />
      <!-- label -->
      <text x="0" y="125" text-anchor="middle" font-family="'Noto Sans Bengali', sans-serif" font-size="13" font-weight="700" fill="#2D2A26">ছোট ভাই</text>
      <text x="0" y="140" text-anchor="middle" font-family="'Noto Sans Bengali', sans-serif" font-size="11" fill="#8B5A2B">= Effect</text>
    </g>

    <!-- Action arrow: customer → mama -->
    <defs>
      <marker id="arrow" viewBox="0 0 10 10" refX="8" refY="5" markerWidth="6" markerHeight="6" orient="auto-start-reverse">
        <path d="M 0 0 L 10 5 L 0 10 z" fill="#8B5A2B" />
      </marker>
    </defs>

    <!-- The unidirectional loop indicator -->
    <g opacity="0.7">
      <path d="M 150 410 Q 400 425 640 410" stroke="#5C8A4E" stroke-width="2" fill="none" stroke-dasharray="4 4" />
      <text x="400" y="448" text-anchor="middle" font-family="'Noto Sans Bengali', sans-serif" font-size="12" fill="#5C8A4E" font-weight="700">এক দিকেই প্রবাহ, unidirectional flow</text>
    </g>
  </svg>
  {caption && (
    <figcaption class="text-center text-sm text-[rgb(var(--text-muted))] mt-2">{caption}</figcaption>
  )}
</figure>
