---
interface Props {
  current: number;
  total: number;
}
const { current, total } = Astro.props;
const pct = Math.round((current / total) * 100);
---
<div class="not-prose mb-4">
  <div class="flex items-center justify-between text-xs text-[rgb(var(--text-muted))] mb-1.5">
    <span>{current} / {total} অধ্যায়</span>
    <span>{pct}%</span>
  </div>
  <div class="h-1.5 rounded-full bg-[rgb(var(--border))] overflow-hidden">
    <div class="h-full bg-[rgb(var(--primary))] transition-[width]" style={`width:${pct}%`}></div>
  </div>
</div>
